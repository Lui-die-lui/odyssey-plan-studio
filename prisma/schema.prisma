generator client {
  provider = "prisma-client-js"
  url       = env("DATABASE_URL")
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  PENDING_DELETION
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id             String  @id @default(cuid())
  provider       String?
  providerUserId String?
  email          String?
  name           String?
  image          String?
  role           UserRole @default(USER)
  aiBlocked      Boolean  @default(false)
  status         UserStatus @default(ACTIVE)
  lastLoginAt    DateTime?
  withdrawRequestedAt DateTime?
  hardDeleteAt       DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  plan           Plan?
  aiDraftUsages AiDraftUsage[]
  aiRequestLogs  AiRequestLog[]

  @@unique([provider, providerUserId])
}

/// One plan per user (1:1). Contains up to five `PlanYear` rows (odyssey years 1–5).
model Plan {
  id        String   @id @default(cuid())
  userId    String   @unique
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  years PlanYear[]
}

/// Single tab/year slot: odyssey year index 1–5 (not calendar year).
model PlanYear {
  id        String @id @default(cuid())
  planId    String
  plan      Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  yearIndex Int

  /// Optional memo / summary for the year.
  note String?

  resourcesScore  Int @default(1)
  interestScore   Int @default(1)
  confidenceScore Int @default(1)
  coherenceScore  Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  goals    PlanYearGoal[]
  keywords PlanYearKeyword[]

  @@unique([planId, yearIndex])
  @@index([planId])
}

/// Ordered goal line items for a plan year (max length enforced in app layer).
model PlanYearGoal {
  id         String   @id @default(cuid())
  planYearId String
  planYear   PlanYear @relation(fields: [planYearId], references: [id], onDelete: Cascade)

  position Int
  text     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planYearId, position])
  @@index([planYearId])
}

/// Ordered keywords for a plan year.
model PlanYearKeyword {
  id         String   @id @default(cuid())
  planYearId String
  planYear   PlanYear @relation(fields: [planYearId], references: [id], onDelete: Cascade)

  position Int
  text     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planYearId, position])
  @@index([planYearId])
}

model AiDraftUsage {
  id String @id @default(cuid())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /** "YYYY-MM" (서버 기준) */
  monthKey String

  /** 월간 AI 초안 생성 누적 횟수 */
  usedCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, monthKey])
  @@index([userId, monthKey])
}

model AiRequestLog {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress     String?
  requestType   String
  success       Boolean
  blockedReason String?
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([requestType, createdAt])
  @@index([userId, createdAt])
}

model SystemConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
